# =========================
# DATABASE CONFIGURATION
# =========================

DB_USER=root
DB_PASSWORD=1234
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ladli_store

# Full Database URL
DB_PASSWORD=1234

DATABASE_URL=mysql+pymysql://root:1234@localhost:3306/ladli_store

# =========================
# JWT AUTHENTICATION
# =========================

SECRET_KEY=your_super_secret_key_here_123456789
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30


# =========================
# PROJECT SETTINGS
# =========================

PROJECT_NAME=Ladli Store API
DEBUG=True


# =========================
# CORS SETTINGS
# =========================

BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173


# =========================
# ADMIN SETTINGS
# =========================

ADMIN_EMAIL=admin@ladli.com
ADMIN_PASSWORD=admin123


# =========================
# CLOUDINARY (OPTIONAL)
# =========================

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=


